<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Posts</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 40px 20px;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    h1 { color: white; font-size: 2em; }

    .nav-links { display: flex; gap: 10px; }

    .nav-links a {
      padding: 8px 18px;
      background: rgba(255,255,255,0.2);
      color: white;
      text-decoration: none;
      border-radius: 5px;
      transition: background 0.3s;
    }

    .nav-links a:hover { background: rgba(255,255,255,0.35); }

    .nav-links a.primary { background: white; color: #667eea; }

    .nav-links a.primary:hover { background: #f0f0f0; }

    .post-card {
      background: white;
      border-radius: 10px;
      padding: 25px 30px;
      margin-bottom: 20px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }

    .post-card h2 { color: #333; margin-bottom: 8px; }

    .post-meta {
      font-size: 0.85em;
      color: #888;
      margin-bottom: 12px;
    }

    .post-excerpt { color: #555; line-height: 1.6; }

    .read-more {
      display: inline-block;
      margin-top: 14px;
      color: #667eea;
      text-decoration: none;
      font-weight: 600;
    }

    .read-more:hover { color: #764ba2; }

    .empty { color: white; text-align: center; margin-top: 60px; font-size: 1.2em; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Posts</h1>
      <div class="nav-links">
        <% if (user) { %>
          <a href="/posts/new" class="primary">+ New Post</a>
          <a href="/logout">Logout</a>
        <% } else { %>
          <a href="/login" class="primary">Login</a>
        <% } %>
      </div>
    </div>

    <% if (posts.length === 0) { %>
      <p class="empty">No posts yet. Be the first to write one!</p>
    <% } %>

    <% posts.slice().reverse().forEach(post => { %>
      <div class="post-card">
        <h2><%= post.title %></h2>
        <p class="post-meta">By <strong><%= post.username %></strong> &middot; <%= new Date(post.createdAt).toLocaleDateString() %></p>
        <p class="post-excerpt"><%= post.content.substring(0, 150) %><%= post.content.length > 150 ? '...' : '' %></p>
        <a href="/posts/<%= post.id %>" class="read-more">Read more &rarr;</a>
      </div>
    <% }) %>
  </div>
</body>
</html>
